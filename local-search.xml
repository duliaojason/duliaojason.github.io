    <title>双创实践</title>
    <link href="/2023/02/25/%E5%8F%8C%E5%88%9B%E5%AE%9E%E8%B7%B5/"/>
    <url>/2023/02/25/%E5%8F%8C%E5%88%9B%E5%AE%9E%E8%B7%B5/</url>
    
    <content type="html"><![CDATA[<h2 id="基于可视化地图定位生成动态旅行手帐"><a href="#基于可视化地图定位生成动态旅行手帐" class="headerlink" title="基于可视化地图定位生成动态旅行手帐"></a>基于可视化地图定位生成动态旅行手帐</h2><h3 id="立项背景"><a href="#立项背景" class="headerlink" title="立项背景"></a>立项背景</h3><ul><li><h4 id="研究目的"><a href="#研究目的" class="headerlink" title="研究目的"></a>研究目的</h4><h5 id="功能："><a href="#功能：" class="headerlink" title="功能："></a>功能：</h5><h5 id="简易制作旅行手帐"><a href="#简易制作旅行手帐" class="headerlink" title="简易制作旅行手帐"></a>简易制作<strong>旅行手帐</strong></h5><h5 id="自动生成旅行视频"><a href="#自动生成旅行视频" class="headerlink" title="自动生成旅行视频"></a>自动生成<strong>旅行视频</strong></h5><h5 id="精准推荐用户所需"><a href="#精准推荐用户所需" class="headerlink" title="精准推荐用户所需"></a><strong>精准推荐</strong>用户所需</h5><h5 id="分享社区，发现精彩"><a href="#分享社区，发现精彩" class="headerlink" title="分享社区，发现精彩"></a><strong>分享社区</strong>，发现精彩</h5><h5 id="通过地图可视化和数据库模型，自动生成包含用户旅行线路、图片、感想等信息的旅行视频，并针对用户数据精准推荐他人旅行线路；"><a href="#通过地图可视化和数据库模型，自动生成包含用户旅行线路、图片、感想等信息的旅行视频，并针对用户数据精准推荐他人旅行线路；" class="headerlink" title="通过地图可视化和数据库模型，自动生成包含用户旅行线路、图片、感想等信息的旅行视频，并针对用户数据精准推荐他人旅行线路；"></a>通过<strong>地图</strong>可视化和数据库模型，自动生成包含用户旅行线路、图片、感想等信息的旅行<strong>视频</strong>，并针对用户数据精准<strong>推荐</strong>他人旅行线路；</h5><h4 id="喜爱旅行热衷分享的我的切实需求"><a href="#喜爱旅行热衷分享的我的切实需求" class="headerlink" title="喜爱旅行热衷分享的我的切实需求"></a><strong>喜爱旅行热衷分享的我的切实需求</strong></h4><h5 id="利用百度地图的足迹"><a href="#利用百度地图的足迹" class="headerlink" title="利用百度地图的足迹"></a>利用百度地图的足迹</h5><h5 id="×无法连点成线，画面凌乱（多亏照片拍的多）"><a href="#×无法连点成线，画面凌乱（多亏照片拍的多）" class="headerlink" title="×无法连点成线，画面凌乱（多亏照片拍的多）"></a>×无法连点成线，画面<strong>凌乱</strong>（多亏照片拍的多）</h5><h5 id="×若没有照片或导航，则线路缺失"><a href="#×若没有照片或导航，则线路缺失" class="headerlink" title="×若没有照片或导航，则线路缺失"></a>×若没有照片或导航，则<strong>线路缺失</strong></h5><h5 id="×名称、感想、线路全靠美图秀秀，格式字体不一且制作费时费力"><a href="#×名称、感想、线路全靠美图秀秀，格式字体不一且制作费时费力" class="headerlink" title="×名称、感想、线路全靠美图秀秀，格式字体不一且制作费时费力"></a>×名称、感想、线路全靠美图秀秀，<strong>格式字体不一</strong>且<strong>制作费时费力</strong></h5><h5 id="×刷屏式的朋友圈内容零散"><a href="#×刷屏式的朋友圈内容零散" class="headerlink" title="×刷屏式的朋友圈内容零散"></a>×刷屏式的朋友圈<strong>内容零散</strong></h5><h5 id="旅行后一直想做Vlog给关注我们行程的亲戚长辈，奈何制作流程复杂，不知如何导入地图，无从下手，最终也不了了之……"><a href="#旅行后一直想做Vlog给关注我们行程的亲戚长辈，奈何制作流程复杂，不知如何导入地图，无从下手，最终也不了了之……" class="headerlink" title="旅行后一直想做Vlog给关注我们行程的亲戚长辈，奈何制作流程复杂，不知如何导入地图，无从下手，最终也不了了之……"></a>旅行后一直想做Vlog给关注我们行程的亲戚长辈，奈何制作流程复杂，不知如何导入地图，无从下手，最终也不了了之……</h5></li></ul><img src="/2023/02/25/%E5%8F%8C%E5%88%9B%E5%AE%9E%E8%B7%B5/1.png" class=""><ul><li><h4 id="国内外研究现状即分析"><a href="#国内外研究现状即分析" class="headerlink" title="国内外研究现状即分析"></a>国内外研究现状即分析</h4><h4 id="–-国内《足迹-自动记录-生轨迹和旅行地图》"><a href="#–-国内《足迹-自动记录-生轨迹和旅行地图》" class="headerlink" title="**–**国内《足迹-自动记录-生轨迹和旅行地图》"></a>**–**国内《足迹-自动记录-生轨迹和旅行地图》</h4><h5 id="√实时定位"><a href="#√实时定位" class="headerlink" title="√实时定位"></a>√实时定位</h5><h5 id="√统计用户步数、里程、时速、海拔信息"><a href="#√统计用户步数、里程、时速、海拔信息" class="headerlink" title="√统计用户步数、里程、时速、海拔信息"></a>√统计用户步数、里程、时速、海拔信息</h5><h5 id="×不可用户自定义，不可导入图片和感想，分享价值差"><a href="#×不可用户自定义，不可导入图片和感想，分享价值差" class="headerlink" title="×不可用户自定义，不可导入图片和感想，分享价值差"></a>×不可用户自定义，不可导入图片和感想，<strong>分享价值差</strong></h5><h5 id="×两点间直线连接，画面观赏性差"><a href="#×两点间直线连接，画面观赏性差" class="headerlink" title="×两点间直线连接，画面观赏性差"></a>×两点间直线连接，画面<strong>观赏性差</strong></h5><h5 id="×要求后台常驻并提供精确位置，易侵犯隐私"><a href="#×要求后台常驻并提供精确位置，易侵犯隐私" class="headerlink" title="×要求后台常驻并提供精确位置，易侵犯隐私"></a>×要求后台常驻并提供精确位置，易侵犯隐私</h5><h5 id="×ios独享"><a href="#×ios独享" class="headerlink" title="×ios独享"></a>×<strong>ios独享</strong></h5><h5 id="√硬性记录-×旅程分享"><a href="#√硬性记录-×旅程分享" class="headerlink" title="√硬性记录 ×旅程分享"></a>√硬性记录 ×旅程分享</h5><h4 id="–国外《travel-boast》"><a href="#–国外《travel-boast》" class="headerlink" title="–国外《travel boast》"></a><strong>–<strong>国外《</strong>travel boast</strong>》</h4><h5 id="√卡通形象选择"><a href="#√卡通形象选择" class="headerlink" title="√卡通形象选择"></a>√卡通形象选择</h5><h5 id="√设置视频长度"><a href="#√设置视频长度" class="headerlink" title="√设置视频长度"></a>√设置视频长度</h5><h5 id="×图标绝大多数需要付费，用户选择余地小"><a href="#×图标绝大多数需要付费，用户选择余地小" class="headerlink" title="×图标绝大多数需要付费，用户选择余地小"></a>×图标绝大多数需要<strong>付费</strong>，用户选择余地小</h5><h5 id="×所有标签、内容和地点信息都需要用户手动输入和设置，用户操作费时费力"><a href="#×所有标签、内容和地点信息都需要用户手动输入和设置，用户操作费时费力" class="headerlink" title="×所有标签、内容和地点信息都需要用户手动输入和设置，用户操作费时费力"></a>×所有标签、内容和地点信息都需要用户<strong>手动输入和设置</strong>，用户操作费时费力</h5><h5 id="×两点间直线或曲线，不能体现具体路线信息"><a href="#×两点间直线或曲线，不能体现具体路线信息" class="headerlink" title="×两点间直线或曲线，不能体现具体路线信息"></a>×两点间<strong>直线或曲线</strong>，不能体现具体路线信息</h5><h5 id="×ios独享-1"><a href="#×ios独享-1" class="headerlink" title="×ios独享"></a>×ios独享</h5><h5 id="√生动有趣-×制作繁琐，格式单一"><a href="#√生动有趣-×制作繁琐，格式单一" class="headerlink" title="√生动有趣  ×制作繁琐，格式单一"></a>√生动有趣  ×制作繁琐，格式单一</h5><img src="/2023/02/25/%E5%8F%8C%E5%88%9B%E5%AE%9E%E8%B7%B5/2.png" class=""><img src="/2023/02/25/%E5%8F%8C%E5%88%9B%E5%AE%9E%E8%B7%B5/3.png" class=""></li><li><h4 id="研究意义"><a href="#研究意义" class="headerlink" title="研究意义"></a>研究意义</h4></li></ul><h4 id=""><a href="#" class="headerlink" title=""></a></h4>]]></content>
    
    
    
